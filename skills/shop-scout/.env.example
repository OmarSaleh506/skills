# shop-scout configuration — copy to ".env", fill in, and load via your runtime.
# ALL values are optional; the defaults shown are what shop-scout assumes.
# ".env" is gitignored. NEVER commit a real FIRECRAWL_API_KEY.

# Backend selection: auto (default) | firecrawl | builtin
SHOP_BACKEND=auto

# --- Firecrawl backends ---
# Leave both commented to use the zero-setup built-in backend; uncomment exactly
# ONE (URL for self-host, KEY for cloud). FIRECRAWL_API_URL wins detection, so do
# not leave it set if you mean to use cloud.
# Self-hosted Firecrawl base URL (recommended; no account/quota).
# Start the stack in references/self-host-firecrawl/, then uncomment:
#FIRECRAWL_API_URL=http://localhost:3002
# Firecrawl cloud key (keep it secret; never commit a real one):
#FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Shopping behavior ---
# Store scope: saudi | global | both
SHOP_SCOPE=both
# Pinned/preferred stores (comma list); extends the bundled lists.
SHOP_STORES=noon.com,amazon.sa,jarir.com
# Max products researched concurrently (higher = faster, more tokens, more rate-limit risk).
SHOP_PARALLEL=3
# Max listings scraped per product (token control).
SHOP_MAX_LISTINGS=5
